//@version=5
indicator("ichi-strata v4.0 (Clean & Stable)", overlay=true, max_labels_count=500)

// ============================================
// ICHIMOKU SETTINGS
// ============================================
conversionPeriods = input.int(9, minval=1, title="Tenkan Length")
basePeriods = input.int(26, minval=1, title="Kijun Length")
laggingSpan2Periods = input.int(52, minval=1, title="Span B Length")
displacement = input.int(26, minval=1, title="Displacement")

donchian(len) => (ta.highest(len) + ta.lowest(len)) / 2

// ============================================
// CURRENT TF ICHIMOKU (for chart display)
// ============================================
tenkan = donchian(conversionPeriods)
kijun = donchian(basePeriods)
spanA = (tenkan + kijun) / 2
spanB = donchian(laggingSpan2Periods)

cloudTopNow = math.max(spanA[displacement - 1], spanB[displacement - 1])
cloudBottomNow = math.min(spanA[displacement - 1], spanB[displacement - 1])
chikou = close[displacement]

// ============================================
// DAILY TF ICHIMOKU
// ============================================
dailyIchimoku() =>
    _tenkan = (ta.highest(conversionPeriods) + ta.lowest(conversionPeriods)) / 2
    _kijun = (ta.highest(basePeriods) + ta.lowest(basePeriods)) / 2
    _spanA = (_tenkan + _kijun) / 2
    _spanB = (ta.highest(laggingSpan2Periods) + ta.lowest(laggingSpan2Periods)) / 2
    _cloudTop = math.max(_spanA[displacement - 1], _spanB[displacement - 1])
    _cloudBottom = math.min(_spanA[displacement - 1], _spanB[displacement - 1])
    _chikou = close[displacement]
    [_tenkan, _kijun, _spanA, _spanB, _cloudTop, _cloudBottom, _chikou, close, high, low]

[dTenkan, dKijun, dSpanA, dSpanB, cloudTopD, cloudBottomD, chikouD, dClose, dHigh, dLow] = request.security(syminfo.tickerid, "D", dailyIchimoku(), lookahead = barmerge.lookahead_off)

// Daily Pivot
pivotD = (dHigh[1] + dLow[1] + dClose[1]) / 3

// ============================================
// 15 MIN TF ICHIMOKU
// ============================================
tf15Ichimoku() =>
    _tenkan = (ta.highest(conversionPeriods) + ta.lowest(conversionPeriods)) / 2
    _kijun = (ta.highest(basePeriods) + ta.lowest(basePeriods)) / 2
    _spanA = (_tenkan + _kijun) / 2
    _spanB = (ta.highest(laggingSpan2Periods) + ta.lowest(laggingSpan2Periods)) / 2
    _cloudTop = math.max(_spanA[displacement - 1], _spanB[displacement - 1])
    _cloudBottom = math.min(_spanA[displacement - 1], _spanB[displacement - 1])
    _chikou = close[displacement]
    [_tenkan, _kijun, _spanA, _spanB, _cloudTop, _cloudBottom, _chikou, close]

[tf15Tenkan, tf15Kijun, tf15SpanA, tf15SpanB, cloudTop15, cloudBottom15, chikou15, close15] = request.security(syminfo.tickerid, "15", tf15Ichimoku(), lookahead = barmerge.lookahead_off)

// 15M Pivot (using daily pivot)
pivot15 = pivotD

// ============================================
// DAILY CONDITIONS
// ============================================
dTenkanAbove = dTenkan > cloudTopD
dKijunAbove  = dKijun > cloudTopD
dChikouAbove = chikouD > cloudTopD
dAbovePivot  = dClose > pivotD

dTenkanBelow = dTenkan < cloudBottomD
dKijunBelow  = dKijun < cloudBottomD
dChikouBelow = chikouD < cloudBottomD
dBelowPivot  = dClose < pivotD

dBull = dTenkanAbove and dKijunAbove and dChikouAbove and dAbovePivot
dBear = dTenkanBelow and dKijunBelow and dChikouBelow and dBelowPivot

// ============================================
// 15 MIN CONDITIONS
// ============================================
tf15TenkanAbove = tf15Tenkan > cloudTop15
tf15KijunAbove  = tf15Kijun > cloudTop15
tf15ChikouAbove = chikou15 > cloudTop15
tf15AbovePivot  = close15 > pivot15

tf15TenkanBelow = tf15Tenkan < cloudBottom15
tf15KijunBelow  = tf15Kijun < cloudBottom15
tf15ChikouBelow = chikou15 < cloudBottom15
tf15BelowPivot  = close15 < pivot15

tf15Bull = tf15TenkanAbove and tf15KijunAbove and tf15ChikouAbove and tf15AbovePivot
tf15Bear = tf15TenkanBelow and tf15KijunBelow and tf15ChikouBelow and tf15BelowPivot

// ============================================
// SIGNAL ENGINE (DAILY + 15M)
// ============================================
buySignal  = dBull and tf15Bull and not (dBull[1] and tf15Bull[1])
sellSignal = dBear and tf15Bear and not (dBear[1] and tf15Bear[1])

// ============================================
// PLOTTING (Current TF for visual)
// ============================================
plot(tenkan, color=color.blue, title="Tenkan")
plot(kijun, color=color.red, title="Kijun")
plot(close, offset = -displacement + 1, color=color.green, title="Chikou")
p1 = plot(spanA, offset = displacement - 1, color=color.new(color.green, 50))
p2 = plot(spanB, offset = displacement - 1, color=color.new(color.red, 50))
fill(p1, p2, color = spanA > spanB ? color.new(color.green, 85) : color.new(color.red, 85))

plot(pivotD, color=color.orange, linewidth=2, title="Daily Pivot")

// ============================================
// SIGNAL LABELS
// ============================================
if buySignal
    label.new(bar_index, low, "BUY\nSL: " + str.tostring(kijun, "#.####"),
        style=label.style_label_up, color=color.green, textcolor=color.white)

if sellSignal
    label.new(bar_index, high, "SELL\nSL: " + str.tostring(kijun, "#.####"),
        style=label.style_label_down, color=color.red, textcolor=color.white)

// ============================================
// DASHBOARD TABLE (Daily + 15M only)
// ============================================
var table t = table.new(position.top_right, 3, 7, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    table.cell(t, 0, 0, "Component", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 0, "Daily", text_color=color.white, text_size=size.small)
    table.cell(t, 2, 0, "15M", text_color=color.white, text_size=size.small)
    
    table.cell(t, 0, 1, "Tenkan", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 1, dTenkanAbove ? "Above" : dTenkanBelow ? "Below" : "Inside", 
               text_color=dTenkanAbove ? color.green : dTenkanBelow ? color.red : color.gray, text_size=size.tiny)
    table.cell(t, 2, 1, tf15TenkanAbove ? "Above" : tf15TenkanBelow ? "Below" : "Inside", 
               text_color=tf15TenkanAbove ? color.green : tf15TenkanBelow ? color.red : color.gray, text_size=size.tiny)
    
    table.cell(t, 0, 2, "Kijun", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 2, dKijunAbove ? "Above" : dKijunBelow ? "Below" : "Inside", 
               text_color=dKijunAbove ? color.green : dKijunBelow ? color.red : color.gray, text_size=size.tiny)
    table.cell(t, 2, 2, tf15KijunAbove ? "Above" : tf15KijunBelow ? "Below" : "Inside", 
               text_color=tf15KijunAbove ? color.green : tf15KijunBelow ? color.red : color.gray, text_size=size.tiny)
    
    table.cell(t, 0, 3, "Chikou", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 3, dChikouAbove ? "Above" : dChikouBelow ? "Below" : "Inside", 
               text_color=dChikouAbove ? color.green : dChikouBelow ? color.red : color.gray, text_size=size.tiny)
    table.cell(t, 2, 3, tf15ChikouAbove ? "Above" : tf15ChikouBelow ? "Below" : "Inside", 
               text_color=tf15ChikouAbove ? color.green : tf15ChikouBelow ? color.red : color.gray, text_size=size.tiny)
    
    table.cell(t, 0, 4, "Pivot", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 4, dAbovePivot ? "Above" : "Below", 
               text_color=dAbovePivot ? color.green : color.red, text_size=size.tiny)
    table.cell(t, 2, 4, tf15AbovePivot ? "Above" : "Below", 
               text_color=tf15AbovePivot ? color.green : color.red, text_size=size.tiny)
    
    table.cell(t, 0, 5, "Market", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 5, dBull ? "BUYERS" : dBear ? "SELLERS" : "NEUTRAL", 
               text_color=dBull ? color.green : dBear ? color.red : color.gray, text_size=size.tiny)
    table.cell(t, 2, 5, tf15Bull ? "BUYERS" : tf15Bear ? "SELLERS" : "NEUTRAL", 
               text_color=tf15Bull ? color.green : tf15Bear ? color.red : color.gray, text_size=size.tiny)
    
    table.cell(t, 0, 6, "Signal", text_color=color.white, text_size=size.tiny)
    table.merge_cells(t, 1, 6, 2, 6)
    table.cell(t, 1, 6, dBull and tf15Bull ? "BUY SIGNAL" : dBear and tf15Bear ? "SELL SIGNAL" : "WAIT", 
               text_color=dBull and tf15Bull ? color.green : dBear and tf15Bear ? color.red : color.gray, text_size=size.small)

// ============================================
// ALERTS
// ============================================
alertcondition(buySignal, "BUY", "Ichimoku + Pivot BUY Signal!")
alertcondition(sellSignal, "SELL", "Ichimoku + Pivot SELL Signal!")

// ============================================
// BACKGROUND
// ============================================
bgcolor(dBull and tf15Bull ? color.new(color.green, 90) : dBear and tf15Bear ? color.new(color.red, 90) : na)