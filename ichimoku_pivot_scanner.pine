//@version=5
indicator("ichi-strata v4.0 (Clean & Stable)", overlay=true, max_labels_count=500)

// ============================================
// ICHIMOKU CORE - CURRENT TF
// ============================================
conversionPeriods = input.int(9, minval=1, title="Tenkan Length")
basePeriods = input.int(26, minval=1, title="Kijun Length")
laggingSpan2Periods = input.int(52, minval=1, title="Span B Length")
displacement = input.int(26, minval=1, title="Displacement")

donchian(len) => (ta.highest(len) + ta.lowest(len)) / 2

// Current TF Ichimoku
tenkan = donchian(conversionPeriods)
kijun = donchian(basePeriods)
spanA = (tenkan + kijun) / 2
spanB = donchian(laggingSpan2Periods)

// Cloud at current position (displaced back from projected)
cloudTopNow = math.max(spanA[displacement - 1], spanB[displacement - 1])
cloudBottomNow = math.min(spanA[displacement - 1], spanB[displacement - 1])

// Chikou (price shifted back)
chikou = close[displacement]

// ============================================
// DAILY TF - ALL CALCULATED INSIDE SECURITY
// ============================================
// Get daily OHLC first
[dClose, dHigh, dLow] = request.security(syminfo.tickerid, "D", [close, high, low], lookahead = barmerge.lookahead_off)

// Get daily Ichimoku - use tuple with inline donchian calculations
dTenkan = request.security(syminfo.tickerid, "D", (ta.highest(conversionPeriods) + ta.lowest(conversionPeriods)) / 2, lookahead = barmerge.lookahead_off)
dKijun = request.security(syminfo.tickerid, "D", (ta.highest(basePeriods) + ta.lowest(basePeriods)) / 2, lookahead = barmerge.lookahead_off)
dSpanA = request.security(syminfo.tickerid, "D", ((ta.highest(conversionPeriods) + ta.lowest(conversionPeriods)) / 2 + (ta.highest(basePeriods) + ta.lowest(basePeriods)) / 2) / 2, lookahead = barmerge.lookahead_off)
dSpanB = request.security(syminfo.tickerid, "D", (ta.highest(laggingSpan2Periods) + ta.lowest(laggingSpan2Periods)) / 2, lookahead = barmerge.lookahead_off)

// Daily cloud at current position
cloudTopDNow = math.max(dSpanA[displacement - 1], dSpanB[displacement - 1])
cloudBottomDNow = math.min(dSpanA[displacement - 1], dSpanB[displacement - 1])

// Daily Chikou
chikouD = dClose[displacement]

// Daily Pivot (from yesterday's HLC)
pivotD = (dHigh[1] + dLow[1] + dClose[1]) / 3

// ============================================
// CURRENT TF PIVOT (Daily Pivot for consistency)
// ============================================
pivot = pivotD  // Use same daily pivot for current TF

// ============================================
// CONDITIONS - CURRENT TF
// ============================================
tfTenkanAbove = tenkan > cloudTopNow
tfKijunAbove  = kijun > cloudTopNow
tfChikouAbove = chikou > cloudTopNow
tfAbovePivot  = close > pivot

tfTenkanBelow = tenkan < cloudBottomNow
tfKijunBelow  = kijun < cloudBottomNow
tfChikouBelow = chikou < cloudBottomNow
tfBelowPivot  = close < pivot

tfBull = tfTenkanAbove and tfKijunAbove and tfChikouAbove and tfAbovePivot
tfBear = tfTenkanBelow and tfKijunBelow and tfChikouBelow and tfBelowPivot

// ============================================
// CONDITIONS - DAILY TF
// ============================================
dTenkanAbove = dTenkan > cloudTopDNow
dKijunAbove  = dKijun > cloudTopDNow
dChikouAbove = chikouD > cloudTopDNow
dAbovePivot  = dClose > pivotD

dTenkanBelow = dTenkan < cloudBottomDNow
dKijunBelow  = dKijun < cloudBottomDNow
dChikouBelow = chikouD < cloudBottomDNow
dBelowPivot  = dClose < pivotD

dBull = dTenkanAbove and dKijunAbove and dChikouAbove and dAbovePivot
dBear = dTenkanBelow and dKijunBelow and dChikouBelow and dBelowPivot

// ============================================
// SIGNAL ENGINE (NON-REPAINT)
// ============================================
buySignal  = dBull and tfBull and not (dBull[1] and tfBull[1])
sellSignal = dBear and tfBear and not (dBear[1] and tfBear[1])

// ============================================
// PLOTTING
// ============================================
plot(tenkan, color=color.blue, title="Tenkan")
plot(kijun, color=color.red, title="Kijun")
plot(close, offset = -displacement + 1, color=color.green, title="Chikou")
p1 = plot(spanA, offset = displacement - 1, color=color.new(color.green, 50))
p2 = plot(spanB, offset = displacement - 1, color=color.new(color.red, 50))
fill(p1, p2, color = spanA > spanB ? color.new(color.green, 85) : color.new(color.red, 85))

plot(pivotD, color=color.orange, linewidth=2, title="Daily Pivot")

// ============================================
// SIGNAL LABELS
// ============================================
if buySignal
    label.new(bar_index, low, "BUY\nSL: " + str.tostring(kijun, "#.####"),
        style=label.style_label_up, color=color.green, textcolor=color.white)

if sellSignal
    label.new(bar_index, high, "SELL\nSL: " + str.tostring(kijun, "#.####"),
        style=label.style_label_down, color=color.red, textcolor=color.white)

// ============================================
// DASHBOARD TABLE
// ============================================
var table t = table.new(position.top_right, 3, 7, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    table.cell(t, 0, 0, "Component", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 0, "Daily", text_color=color.white, text_size=size.small)
    table.cell(t, 2, 0, "Current TF", text_color=color.white, text_size=size.small)
    
    table.cell(t, 0, 1, "Tenkan", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 1, dTenkanAbove ? "Above" : dTenkanBelow ? "Below" : "Inside", 
               text_color=dTenkanAbove ? color.green : dTenkanBelow ? color.red : color.gray, text_size=size.tiny)
    table.cell(t, 2, 1, tfTenkanAbove ? "Above" : tfTenkanBelow ? "Below" : "Inside", 
               text_color=tfTenkanAbove ? color.green : tfTenkanBelow ? color.red : color.gray, text_size=size.tiny)
    
    table.cell(t, 0, 2, "Kijun", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 2, dKijunAbove ? "Above" : dKijunBelow ? "Below" : "Inside", 
               text_color=dKijunAbove ? color.green : dKijunBelow ? color.red : color.gray, text_size=size.tiny)
    table.cell(t, 2, 2, tfKijunAbove ? "Above" : tfKijunBelow ? "Below" : "Inside", 
               text_color=tfKijunAbove ? color.green : tfKijunBelow ? color.red : color.gray, text_size=size.tiny)
    
    table.cell(t, 0, 3, "Chikou", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 3, dChikouAbove ? "Above" : dChikouBelow ? "Below" : "Inside", 
               text_color=dChikouAbove ? color.green : dChikouBelow ? color.red : color.gray, text_size=size.tiny)
    table.cell(t, 2, 3, tfChikouAbove ? "Above" : tfChikouBelow ? "Below" : "Inside", 
               text_color=tfChikouAbove ? color.green : tfChikouBelow ? color.red : color.gray, text_size=size.tiny)
    
    table.cell(t, 0, 4, "Pivot", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 4, dAbovePivot ? "Above" : "Below", 
               text_color=dAbovePivot ? color.green : color.red, text_size=size.tiny)
    table.cell(t, 2, 4, tfAbovePivot ? "Above" : "Below", 
               text_color=tfAbovePivot ? color.green : color.red, text_size=size.tiny)
    
    table.cell(t, 0, 5, "Market", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 5, dBull ? "BUYERS" : dBear ? "SELLERS" : "NEUTRAL", 
               text_color=dBull ? color.green : dBear ? color.red : color.gray, text_size=size.tiny)
    table.cell(t, 2, 5, tfBull ? "BUYERS" : tfBear ? "SELLERS" : "NEUTRAL", 
               text_color=tfBull ? color.green : tfBear ? color.red : color.gray, text_size=size.tiny)
    
    table.cell(t, 0, 6, "Signal", text_color=color.white, text_size=size.tiny)
    table.merge_cells(t, 1, 6, 2, 6)
    table.cell(t, 1, 6, dBull and tfBull ? "BUY SIGNAL" : dBear and tfBear ? "SELL SIGNAL" : "WAIT", 
               text_color=dBull and tfBull ? color.green : dBear and tfBear ? color.red : color.gray, text_size=size.small)

// ============================================
// ALERTS
// ============================================
alertcondition(buySignal, "BUY", "Ichimoku + Pivot BUY Signal!")
alertcondition(sellSignal, "SELL", "Ichimoku + Pivot SELL Signal!")

// ============================================
// BACKGROUND
// ============================================
bgcolor(dBull and tfBull ? color.new(color.green, 90) : dBear and tfBear ? color.new(color.red, 90) : na)
