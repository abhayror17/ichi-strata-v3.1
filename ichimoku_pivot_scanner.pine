//@version=6
indicator("ichi-strata-v3.1: Ichimoku + Pivot Points Scanner [Multi-TF]", overlay=true, max_labels_count=500)

// ============================================
// ICHIMOKU CLOUD (Official Code)
// ============================================
conversionPeriods = input.int(9, minval=1, title="Conversion Line Length")
basePeriods = input.int(26, minval=1, title="Base Line Length")
laggingSpan2Periods = input.int(52, minval=1, title="Leading Span B Length")
displacement = input.int(26, minval=1, title="Lagging Span")
donchian(len) => math.avg(ta.lowest(len), ta.highest(len))
conversionLine = donchian(conversionPeriods)
baseLine = donchian(basePeriods)
leadLine1 = math.avg(conversionLine, baseLine)
leadLine2 = donchian(laggingSpan2Periods)
plot(conversionLine, color=#2962FF, title="Conversion Line")
plot(baseLine, color=#B71C1C, title="Base Line")
plot(close, offset = -displacement + 1, color=#43A047, title="Lagging Span")
p1 = plot(leadLine1, offset = displacement - 1, color=#A5D6A7, title="Leading Span A")
p2 = plot(leadLine2, offset = displacement - 1, color=#EF9A9A, title="Leading Span B")
plot(leadLine1 > leadLine2 ? leadLine1 : leadLine2, offset = displacement - 1, title = "Kumo Cloud Upper Line", display = display.none)
plot(leadLine1 < leadLine2 ? leadLine1 : leadLine2, offset = displacement - 1, title = "Kumo Cloud Lower Line", display = display.none)
fill(p1, p2, title = "Cloud Fill", color = leadLine1 > leadLine2 ? color.rgb(67, 160, 71, 90) : color.rgb(244, 67, 54, 90))

// Cloud Top/Bottom for analysis (current position)
cloudTop = leadLine1 > leadLine2 ? leadLine1 : leadLine2
cloudBottom = leadLine1 < leadLine2 ? leadLine1 : leadLine2

// ============================================
// DAILY ICHIMOKU
// ============================================
[conversionLineD, baseLineD, leadLine1D, leadLine2D, closeD] = request.security(syminfo.tickerid, "D", [donchian(conversionPeriods), donchian(basePeriods), math.avg(donchian(conversionPeriods), donchian(basePeriods)), donchian(laggingSpan2Periods), close], lookahead = barmerge.lookahead_on)

// Daily cloud at current position
cloudTopD = leadLine1D > leadLine2D ? leadLine1D : leadLine2D
cloudBottomD = leadLine1D < leadLine2D ? leadLine1D : leadLine2D

// Daily cloud at historical position (for Chikou comparison - displacement bars ago)
cloudTopDChikou = leadLine1D[displacement] > leadLine2D[displacement] ? leadLine1D[displacement] : leadLine2D[displacement]
cloudBottomDChikou = leadLine1D[displacement] < leadLine2D[displacement] ? leadLine1D[displacement] : leadLine2D[displacement]

// Daily Chikou - daily close from displacement bars ago
chikouD = closeD[displacement]

// ============================================
// 15 MIN ICHIMOKU
// ============================================
[conversionLine15, baseLine15, leadLine115, leadLine215, close15] = request.security(syminfo.tickerid, "15", [donchian(conversionPeriods), donchian(basePeriods), math.avg(donchian(conversionPeriods), donchian(basePeriods)), donchian(laggingSpan2Periods), close], lookahead = barmerge.lookahead_on)

// 15M cloud at current position
cloudTop15 = leadLine115 > leadLine215 ? leadLine115 : leadLine215
cloudBottom15 = leadLine115 < leadLine215 ? leadLine115 : leadLine215

// 15M cloud at historical position (for Chikou comparison)
cloudTop15Chikou = leadLine115[displacement] > leadLine215[displacement] ? leadLine115[displacement] : leadLine215[displacement]
cloudBottom15Chikou = leadLine115[displacement] < leadLine215[displacement] ? leadLine115[displacement] : leadLine215[displacement]

// 15M Chikou
chikou15 = close15[displacement]

// ============================================
// PIVOT POINTS (Official Code)
// ============================================
pivotTypeInput           = input.string(title="Type", defval="Traditional", options=["Traditional", "Fibonacci", "Woodie", "Classic", "DM", "Camarilla"])
pivotAnchorInput         = input.string(title="Pivots Timeframe", defval="Auto", options=["Auto", "Daily", "Weekly", "Monthly", "Quarterly", "Yearly", "Biyearly", "Triyearly", "Quinquennially", "Decennially"])
maxHistoricalPivotsInput = input.int(title="Number of Pivots Back", defval=15, minval=1, maxval=200, display = display.none)
isDailyBasedInput        = input.bool(title="Use Daily-based Values", defval=true, display = display.none)
showLabelsInput          = input.bool(title="Show Labels", defval=true, group="labels", display = display.none)
showPricesInput          = input.bool(title="Show Prices", defval=true, group="labels", display = display.none)
positionLabelsInput      = input.string("Left", "Labels Position", options=["Left", "Right"], group="labels", display = display.none, active = showLabelsInput or showPricesInput)
linewidthInput           = input.int(title="Line Width", defval=1, minval=1, maxval=100, group="levels", display = display.none)

DEFAULT_COLOR = #FB8C00

showLevel2and3 = pivotTypeInput != "DM"
showLevel4 = pivotTypeInput != "DM" and pivotTypeInput != "Fibonacci"
showLevel5 = pivotTypeInput == "Traditional" or pivotTypeInput == "Camarilla"

pColorInput = input.color(DEFAULT_COLOR, "P", inline="P", group="levels", display = display.none)
pShowInput = input.bool(true, "", inline="P", group="levels", display = display.none)
s1ColorInput = input.color(DEFAULT_COLOR, "S1", inline="S1/R1" , group="levels", display = display.none)
s1ShowInput = input.bool(true, "", inline="S1/R1", group="levels", display = display.none)
r1ColorInput = input.color(DEFAULT_COLOR, "R1", inline="S1/R1", group="levels", display = display.none)
r1ShowInput = input.bool(true, "", inline="S1/R1", group="levels", display = display.none)
s2ColorInput = input.color(DEFAULT_COLOR, "S2", inline="S2/R2", group="levels", display = display.none, active = showLevel2and3)
s2ShowInput = input.bool(true, "", inline="S2/R2", group="levels", display = display.none, active = showLevel2and3)
r2ColorInput = input.color(DEFAULT_COLOR, "R2", inline="S2/R2", group="levels", display = display.none, active = showLevel2and3)
r2ShowInput = input.bool(true, "", inline="S2/R2", group="levels", display = display.none, active = showLevel2and3)
s3ColorInput = input.color(DEFAULT_COLOR, "S3", inline="S3/R3", group="levels", display = display.none, active = showLevel2and3)
s3ShowInput = input.bool(true, "", inline="S3/R3", group="levels", display = display.none, active = showLevel2and3)
r3ColorInput = input.color(DEFAULT_COLOR, "R3", inline="S3/R3", group="levels", display = display.none, active = showLevel2and3)
r3ShowInput = input.bool(true, "", inline="S3/R3", group="levels", display = display.none, active = showLevel2and3)
s4ColorInput = input.color(DEFAULT_COLOR, "S4", inline="S4/R4", group="levels", display = display.none, active = showLevel4)
s4ShowInput = input.bool(true, "", inline="S4/R4", group="levels", display = display.none, active = showLevel4)
r4ColorInput = input.color(DEFAULT_COLOR, "R4", inline="S4/R4", group="levels", display = display.none, active = showLevel4)
r4ShowInput = input.bool(true, "", inline="S4/R4", group="levels", display = display.none, active = showLevel4)
s5ColorInput = input.color(DEFAULT_COLOR, "S5", inline="S5/R5", group="levels", display = display.none, active = showLevel5)
s5ShowInput = input.bool(true, "", inline="S5/R5", group="levels", display = display.none, active = showLevel5)
r5ColorInput = input.color(DEFAULT_COLOR, "R5", inline="S5/R5", group="levels", display = display.none, active = showLevel5)
r5ShowInput = input.bool(true, "", inline="S5/R5", group="levels", display = display.none, active = showLevel5)

type graphicSettings
    string levelName
    color levelColor
    bool showLevel

var graphicSettingsArray = array.from(
      graphicSettings.new(" P", pColorInput, pShowInput),
      graphicSettings.new("R1", r1ColorInput, r1ShowInput), graphicSettings.new("S1", s1ColorInput, s1ShowInput),
      graphicSettings.new("R2", r2ColorInput, r2ShowInput), graphicSettings.new("S2", s2ColorInput, s2ShowInput),
      graphicSettings.new("R3", r3ColorInput, r3ShowInput), graphicSettings.new("S3", s3ColorInput, s3ShowInput),
      graphicSettings.new("R4", r4ColorInput, r4ShowInput), graphicSettings.new("S4", s4ColorInput, s4ShowInput),
      graphicSettings.new("R5", r5ColorInput, r5ShowInput), graphicSettings.new("S5", s5ColorInput, s5ShowInput))

autoAnchor = switch
    timeframe.isintraday => timeframe.multiplier <= 15 ? "1D" : "1W"
    timeframe.isdaily    => "1M"
    => "12M"

pivotTimeframe = switch pivotAnchorInput
    "Auto"      => autoAnchor
    "Daily"     => "1D"
    "Weekly"    => "1W"
    "Monthly"   => "1M"
    "Quarterly" => "3M"
    => "12M"

pivotYearMultiplier = switch pivotAnchorInput
    "Biyearly"       => 2
    "Triyearly"      => 3
    "Quinquennially" => 5
    "Decennially"    => 10
    => 1

numOfPivotLevels = switch pivotTypeInput
    "Traditional" => 11
    "Camarilla"   => 11
    "Woodie"      => 9
    "Classic"     => 9
    "Fibonacci"   => 7
    "DM"          => 3

type pivotGraphic
    line pivotLine
    label pivotLabel

method delete(pivotGraphic graphic) =>
    graphic.pivotLine.delete()
    graphic.pivotLabel.delete()

var drawnGraphics = matrix.new<pivotGraphic>()

localPivotTimeframeChange = timeframe.change(pivotTimeframe) and year % pivotYearMultiplier == 0
securityPivotTimeframeChange = timeframe.change(timeframe.period) and year % pivotYearMultiplier == 0

pivotTimeframeChangeCounter(condition) =>
    var count = 0
    if condition and bar_index > 0
        count += 1
    count

localPivots = ta.pivot_point_levels(pivotTypeInput, localPivotTimeframeChange)
securityPivotPointsArray = ta.pivot_point_levels(pivotTypeInput, securityPivotTimeframeChange)

securityTimeframe = timeframe.isintraday ? "1D" : timeframe.period
[securityPivots, securityPivotCounter] = request.security(syminfo.tickerid, pivotTimeframe, [securityPivotPointsArray, pivotTimeframeChangeCounter(securityPivotTimeframeChange)], lookahead = barmerge.lookahead_on)
pivotPointsArray = isDailyBasedInput ? securityPivots : localPivots

affixOldPivots(endTime) =>
    if drawnGraphics.rows() > 0
        lastGraphics = drawnGraphics.row(drawnGraphics.rows() - 1)
        for graphic in lastGraphics
            graphic.pivotLine.set_x2(endTime)
            if positionLabelsInput == "Right"
                graphic.pivotLabel.set_x(endTime)

drawNewPivots(startTime) =>
    newGraphics = array.new<pivotGraphic>()
    for [index, coord] in pivotPointsArray
        levelSettings = graphicSettingsArray.get(index)
        if not na(coord) and levelSettings.showLevel
            lineEndTime = startTime + timeframe.in_seconds(pivotTimeframe) * 1000 * pivotYearMultiplier
            pivotLine = line.new(startTime, coord, lineEndTime, coord, xloc = xloc.bar_time, color=levelSettings.levelColor, width=linewidthInput)
            pivotLabel = label.new(x = positionLabelsInput == "Left" ? startTime : lineEndTime,
                               y = coord,
                               text = (showLabelsInput ? levelSettings.levelName + " " : "") + (showPricesInput ? "(" + str.tostring(coord, format.mintick) + ")" : ""),
                               style = positionLabelsInput == "Left" ? label.style_label_right : label.style_label_left,
                               textcolor = levelSettings.levelColor,
                               color = #00000000,
                               xloc=xloc.bar_time)
            newGraphics.push(pivotGraphic.new(pivotLine, pivotLabel))
    drawnGraphics.add_row(array_id = newGraphics)
    if drawnGraphics.rows() > maxHistoricalPivotsInput
        oldGraphics = drawnGraphics.remove_row(0)
        for graphic in oldGraphics
            graphic.delete()

localPivotDrawConditionStatic = not isDailyBasedInput and localPivotTimeframeChange
securityPivotDrawConditionStatic = isDailyBasedInput and securityPivotCounter != securityPivotCounter[1]

var isMultiYearly = array.from("Biyearly", "Triyearly", "Quinquennially", "Decennially").includes(pivotAnchorInput)
localPivotDrawConditionDeveloping = not isDailyBasedInput and time_close == time_close(pivotTimeframe) and not isMultiYearly
securityPivotDrawConditionDeveloping = false

if (securityPivotDrawConditionStatic or localPivotDrawConditionStatic)
    affixOldPivots(time)
    drawNewPivots(time)

var FIRST_BAR_TIME = time
if (barstate.islastconfirmedhistory and drawnGraphics.columns() == 0)
    if not na(securityPivots) and securityPivotCounter > 0
        if isDailyBasedInput
            drawNewPivots(FIRST_BAR_TIME)
        else
            runtime.error("Not enough intraday data to calculate Pivot Points.")
    else
        runtime.error("Not enough data to calculate Pivot Points.")

// ============================================
// SCANNER SETTINGS
// ============================================
showSignalLabels = input.bool(true, "Show Signal Labels", group="Scanner")
showTable = input.bool(true, "Show Info Table", group="Scanner")
alertOnBuy = input.bool(true, "Buy Signal Alerts", group="Scanner")
alertOnSell = input.bool(true, "Sell Signal Alerts", group="Scanner")

// ============================================
// GET PIVOT VALUES FOR ANALYSIS
// ============================================
// Daily pivot for analysis
dailyPivotArray = ta.pivot_point_levels(pivotTypeInput, timeframe.change("D"))
pivotD = array.get(dailyPivotArray, 0)

// Current pivot
pivotCurrent = array.get(pivotPointsArray, 0)

// ============================================
// DAILY MARKET CONDITIONS
// ============================================
dailyTenkanAboveCloud = conversionLineD > cloudTopD
dailyTenkanBelowCloud = conversionLineD < cloudBottomD
dailyKijunAboveCloud = baseLineD > cloudTopD
dailyKijunBelowCloud = baseLineD < cloudBottomD
dailyChikouAboveCloud = chikouD > cloudTopDChikou        // Compare to HISTORICAL cloud
dailyChikouBelowCloud = chikouD < cloudBottomDChikou     // Compare to HISTORICAL cloud
dailyPriceAbovePivot = closeD > pivotD                   // Use daily close
dailyPriceBelowPivot = closeD < pivotD                   // Use daily close

dailyBuyersMarket = dailyTenkanAboveCloud and dailyKijunAboveCloud and dailyChikouAboveCloud and dailyPriceAbovePivot
dailySellersMarket = dailyTenkanBelowCloud and dailyKijunBelowCloud and dailyChikouBelowCloud and dailyPriceBelowPivot

// ============================================
// 15 MIN MARKET CONDITIONS
// ============================================
tf15TenkanAboveCloud = conversionLine15 > cloudTop15
tf15TenkanBelowCloud = conversionLine15 < cloudBottom15
tf15KijunAboveCloud = baseLine15 > cloudTop15
tf15KijunBelowCloud = baseLine15 < cloudBottom15
tf15ChikouAboveCloud = chikou15 > cloudTop15Chikou       // Compare to HISTORICAL cloud
tf15ChikouBelowCloud = chikou15 < cloudBottom15Chikou    // Compare to HISTORICAL cloud
tf15PriceAbovePivot = close15 > pivotD                   // 15M close vs daily pivot
tf15PriceBelowPivot = close15 < pivotD                   // 15M close vs daily pivot

tf15BuyersMarket = tf15TenkanAboveCloud and tf15KijunAboveCloud and tf15ChikouAboveCloud and tf15PriceAbovePivot
tf15SellersMarket = tf15TenkanBelowCloud and tf15KijunBelowCloud and tf15ChikouBelowCloud and tf15PriceBelowPivot

// ============================================
// SIGNAL GENERATION (DAILY + 15M)
// ============================================
var bool buySignal = false
buySignal := dailyBuyersMarket and tf15BuyersMarket and not buySignal[1]

var bool sellSignal = false
sellSignal := dailySellersMarket and tf15SellersMarket and not sellSignal[1]

// ============================================
// SIGNAL LABELS
// ============================================
if showSignalLabels and buySignal
    label.new(bar_index, low, "BUY\nSL: " + str.tostring(baseLine, "#.####"), style=label.style_label_up, color=color.green, textcolor=color.white, size=size.normal)

if showSignalLabels and sellSignal
    label.new(bar_index, high, "SELL\nSL: " + str.tostring(baseLine, "#.####"), style=label.style_label_down, color=color.red, textcolor=color.white, size=size.normal)

// ============================================
// INFO TABLE (Daily + 15M only)
// ============================================
var table infoTable = table.new(position.top_right, 3, 10, bgcolor=color.new(color.black, 80), border_width=1)

if showTable and barstate.islast
    table.cell(infoTable, 0, 0, "Component", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, "Daily", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 2, 0, "15M", text_color=color.white, text_size=size.small)
    
    table.cell(infoTable, 0, 1, "Tenkan vs Cloud", text_color=color.white, text_size=size.tiny)
    table.cell(infoTable, 1, 1, dailyTenkanAboveCloud ? "Above" : dailyTenkanBelowCloud ? "Below" : "Inside", text_color=dailyTenkanAboveCloud ? color.green : dailyTenkanBelowCloud ? color.red : color.gray, text_size=size.tiny)
    table.cell(infoTable, 2, 1, tf15TenkanAboveCloud ? "Above" : tf15TenkanBelowCloud ? "Below" : "Inside", text_color=tf15TenkanAboveCloud ? color.green : tf15TenkanBelowCloud ? color.red : color.gray, text_size=size.tiny)
    
    table.cell(infoTable, 0, 2, "Kijun vs Cloud", text_color=color.white, text_size=size.tiny)
    table.cell(infoTable, 1, 2, dailyKijunAboveCloud ? "Above" : dailyKijunBelowCloud ? "Below" : "Inside", text_color=dailyKijunAboveCloud ? color.green : dailyKijunBelowCloud ? color.red : color.gray, text_size=size.tiny)
    table.cell(infoTable, 2, 2, tf15KijunAboveCloud ? "Above" : tf15KijunBelowCloud ? "Below" : "Inside", text_color=tf15KijunAboveCloud ? color.green : tf15KijunBelowCloud ? color.red : color.gray, text_size=size.tiny)
    
    table.cell(infoTable, 0, 3, "Chikou vs Cloud", text_color=color.white, text_size=size.tiny)
    table.cell(infoTable, 1, 3, dailyChikouAboveCloud ? "Above" : dailyChikouBelowCloud ? "Below" : "Inside", text_color=dailyChikouAboveCloud ? color.green : dailyChikouBelowCloud ? color.red : color.gray, text_size=size.tiny)
    table.cell(infoTable, 2, 3, tf15ChikouAboveCloud ? "Above" : tf15ChikouBelowCloud ? "Below" : "Inside", text_color=tf15ChikouAboveCloud ? color.green : tf15ChikouBelowCloud ? color.red : color.gray, text_size=size.tiny)
    
    table.cell(infoTable, 0, 4, "Price vs Pivot", text_color=color.white, text_size=size.tiny)
    table.cell(infoTable, 1, 4, dailyPriceAbovePivot ? "Above" : "Below", text_color=dailyPriceAbovePivot ? color.green : color.red, text_size=size.tiny)
    table.cell(infoTable, 2, 4, tf15PriceAbovePivot ? "Above" : "Below", text_color=tf15PriceAbovePivot ? color.green : color.red, text_size=size.tiny)
    
    table.cell(infoTable, 0, 5, "Market Direction", text_color=color.white, text_size=size.tiny)
    table.cell(infoTable, 1, 5, dailyBuyersMarket ? "BUYERS" : dailySellersMarket ? "SELLERS" : "NEUTRAL", text_color=dailyBuyersMarket ? color.green : dailySellersMarket ? color.red : color.gray, text_size=size.tiny)
    table.cell(infoTable, 2, 5, tf15BuyersMarket ? "BUYERS" : tf15SellersMarket ? "SELLERS" : "NEUTRAL", text_color=tf15BuyersMarket ? color.green : tf15SellersMarket ? color.red : color.gray, text_size=size.tiny)
    
    table.cell(infoTable, 0, 6, "Signal Status", text_color=color.white, text_size=size.tiny)
    table.merge_cells(infoTable, 1, 6, 2, 6)
    table.cell(infoTable, 1, 6, dailyBuyersMarket and tf15BuyersMarket ? "BUY SIGNAL" : dailySellersMarket and tf15SellersMarket ? "SELL SIGNAL" : "WAIT", text_color=dailyBuyersMarket and tf15BuyersMarket ? color.green : dailySellersMarket and tf15SellersMarket ? color.red : color.gray, text_size=size.small)
    
    table.cell(infoTable, 0, 7, "SL (Kijun)", text_color=color.white, text_size=size.tiny)
    table.merge_cells(infoTable, 1, 7, 2, 7)
    table.cell(infoTable, 1, 7, str.tostring(baseLine, "#.####"), text_color=color.orange, text_size=size.tiny)
    
    table.cell(infoTable, 0, 8, "Pivot", text_color=color.white, text_size=size.tiny)
    table.merge_cells(infoTable, 1, 8, 2, 8)
    table.cell(infoTable, 1, 8, str.tostring(pivotCurrent, "#.####"), text_color=color.yellow, text_size=size.tiny)

// ============================================
// ALERTS
// ============================================
alertcondition(alertOnBuy and buySignal, "Buy Signal", "Ichimoku + Pivot BUY Signal!")
alertcondition(alertOnSell and sellSignal, "Sell Signal", "Ichimoku + Pivot SELL Signal!")

// ============================================
// BACKGROUND COLOR
// ============================================
bgcolor(dailyBuyersMarket and tf15BuyersMarket ? color.new(color.green, 90) : dailySellersMarket and tf15SellersMarket ? color.new(color.red, 90) : na)